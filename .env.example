# Job Intelligence release-control flag.
# Release-control only — NOT a security boundary. Database RLS and
# server-side authorisation remain effective regardless of this value.
# Default is disabled; the public Jobs experience stays on the
# "Coming soon" page until owner approval.
VITE_JOBS_ENABLED=false

# Career Intelligence Graph — governance enforcement flag (Epic 1).
# Release-control only. The authoritative switch lives in
# public.cig_governance_settings.lifecycle_enforced (default false); this
# client flag mirrors it so client code can surface future governance UI
# without an extra roundtrip. Do NOT flip this without also flipping the
# database setting.
VITE_CIG_LIFECYCLE_ENFORCED=false

# Employer Portal release-control flag.
# Release-control only — NOT a security boundary. Database RLS and
# server-side authorisation remain effective regardless of this value.
# Default is disabled until Phase G has been verified and approved.
VITE_EMPLOYER_PORTAL_ENABLED=false
